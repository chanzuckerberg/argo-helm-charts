{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "argo.helm.charts/envoy-gateway-resources",
  "title": "envoy-gateway-resources",
  "type": "object",
  "properties": {
    "alternateNames": {
      "type": "array"
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxReplicas": {
          "type": "integer"
        },
        "minReplicas": {
          "type": "integer"
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer"
        }
      }
    },
    "awsRegion": {
      "type": "string"
    },
    "baseDomain": {
      "type": "string"
    },
    "envoyService": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        }
      }
    },
    "gatewayName": {
      "type": "string"
    },
    "geoip": {
      "type": "object",
      "properties": {
        "blockedCountries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "listenerSets": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "from": {
          "type": "string"
        },
        "namespaceSelector": {
          "type": "object"
        }
      }
    },
    "proxyProtocol": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string"
            },
            "memory": {
              "type": "string"
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "tlsPassthrough": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hostnames": {
          "type": "array"
        }
      }
    }
  }
}
