{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "argo.helm.charts/envoy-gateway-resources",
  "title": "envoy-gateway-resources",
  "type": "object",
  "properties": {
    "alternateNames": {
      "type": "array"
    },
    "baseDomain": {
      "type": "string"
    },
    "clusterName": {
      "type": "string"
    },
    "gatewayName": {
      "type": "string"
    },
    "geoip": {
      "type": "object",
      "properties": {
        "blockedCountries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedResponseBody": {
          "type": "string"
        },
        "blockedStatusCode": {
          "type": "integer"
        },
        "enabled": {
          "type": "boolean"
        },
        "s3": {
          "type": "object",
          "properties": {
            "bucketPath": {
              "type": "string"
            },
            "dbFileName": {
              "type": "string"
            },
            "iamRoleArn": {
              "type": "string"
            },
            "awsCliImage": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
