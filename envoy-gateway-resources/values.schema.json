{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "argo.helm.charts/envoy-gateway-resources",
  "title": "envoy-gateway-resources",
  "type": "object",
  "properties": {
    "alternateNames": {
      "type": "array"
    },
    "awsRegion": {
      "type": "string"
    },
    "baseDomain": {
      "type": "string"
    },
    "envoyService": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        }
      }
    },
    "gatewayName": {
      "type": "string"
    },
    "geoip": {
      "type": "object",
      "properties": {
        "blockedCountries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "listenerSets": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "from": {
          "type": "string"
        },
        "namespaceSelector": {
          "type": "object"
        }
      }
    },
    "proxyProtocol": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}
